# Local E2E — copy to .env.test.local (gitignored). Do not commit secrets.
# Run: npm run test:e2e  (or dotenv -o -e .env.test.local -- npx playwright test)
# Generated block: npm run seed:e2e

# CONSISTENCY CHECK: local E2E uses staging Supabase (cmzyxpxfyvdvbsykjvsg) — same DB as .env.local.
# App URL is localhost via scripts/testEnv.ts; do not set PLAYWRIGHT_BASE_URL here.

TEST_ENV=local

PLAYWRIGHT_CONSUMER_EMAIL=e2e-consumer@mywealthmaps.test
PLAYWRIGHT_CONSUMER_PASSWORD=E2eTest!2026Mwm
PLAYWRIGHT_HOUSEHOLD_ID=<run seed-e2e-fixtures.ts>
PLAYWRIGHT_ADVISOR_CLIENT_HOUSEHOLD_ID=<advisor-client-household-uuid-from-seed>

PLAYWRIGHT_ADVISOR_EMAIL=e2e-advisor@mywealthmaps.test
PLAYWRIGHT_ADVISOR_PASSWORD=E2eTest!2026Mwm

PLAYWRIGHT_ATTORNEY_EMAIL=e2e-attorney@mywealthmaps.test
PLAYWRIGHT_ATTORNEY_PASSWORD=E2eTest!2026Mwm

PLAYWRIGHT_CONSUMER_TIER1_EMAIL=e2e-consumer-tier1@mywealthmaps.test
PLAYWRIGHT_CONSUMER_TIER1_PASSWORD=E2eTest!2026Mwm

PLAYWRIGHT_ADVISOR_REFERRAL_CODE=e2eadv01
PLAYWRIGHT_ATTORNEY_REFERRAL_CODE=e2eatt01

SEED_ADVISOR_EMAIL=e2e-advisor@mywealthmaps.test
SEED_CLIENT_EMAIL=e2e-advisor-client@mywealthmaps.test

REQUIRE_PRIVILEGED_MFA=false

PLAYWRIGHT_STRIPE_WEBHOOK_SECRET=whsec_YOUR_TEST_WEBHOOK_SECRET
PLAYWRIGHT_ADVISOR_FIRM_STARTER_PRICE_ID=price_YOUR_TEST_FIRM_STARTER_ID

NEXT_PUBLIC_SUPABASE_URL=https://cmzyxpxfyvdvbsykjvsg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<from .env.local>
SUPABASE_SERVICE_ROLE_KEY=<from .env.local — setup/teardown only>
RECOMPUTE_SECRET=<from .env.local — optional>

E2E_SKIP_RECOMPUTE=false
