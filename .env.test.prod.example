# ============================================================
# PRODUCTION E2E — .env.test.prod
#
# Quick start (same Supabase project as local E2E):
#   cp .env.test.prod.example .env.test.prod
#   # Copy NEXT_PUBLIC_SUPABASE_*, SUPABASE_SERVICE_ROLE_KEY, household IDs,
#   #   PLAYWRIGHT_* emails/passwords, and Stripe price IDs from .env.test
#   # Set PLAYWRIGHT_BASE_URL=https://www.mywealthmaps.com
#
# NEVER commit .env.test.prod
# Run: npm run test:e2e:prod:smoke -- --workers=1
# ============================================================

PLAYWRIGHT_BASE_URL=https://www.mywealthmaps.com

# Supabase (same project as .env.test if you share staging/prod DB)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# E2E households — copy UUIDs from .env.test after npm run seed:e2e
PLAYWRIGHT_HOUSEHOLD_ID=
PLAYWRIGHT_ADVISOR_CLIENT_HOUSEHOLD_ID=

PLAYWRIGHT_CONSUMER_EMAIL=e2e-consumer@mywealthmaps.test
PLAYWRIGHT_CONSUMER_PASSWORD=E2eTest!2026Mwm

PLAYWRIGHT_ADVISOR_EMAIL=e2e-advisor@mywealthmaps.test
PLAYWRIGHT_ADVISOR_PASSWORD=E2eTest!2026Mwm

PLAYWRIGHT_ATTORNEY_EMAIL=e2e-attorney@mywealthmaps.test
PLAYWRIGHT_ATTORNEY_PASSWORD=E2eTest!2026Mwm

PLAYWRIGHT_STRIPE_WEBHOOK_SECRET=
# Live IDs only — copy from Vercel Production STRIPE_PRICE_ADVISOR_*_MONTHLY (not .env.test test IDs)
PLAYWRIGHT_ADVISOR_FIRM_STARTER_PRICE_ID=
PLAYWRIGHT_ADVISOR_FIRM_ENTERPRISE_PRICE_ID=

REQUIRE_PRIVILEGED_MFA=false
