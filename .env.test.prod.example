# ============================================================
# PRODUCTION E2E — .env.test.prod
# Copy this file to .env.test.prod and fill in real values.
# NEVER commit .env.test.prod — it contains production secrets.
# Run production E2E deliberately and infrequently.
# ============================================================

# Target
PLAYWRIGHT_BASE_URL=https://www.mywealthmaps.com

# Supabase — PRODUCTION keys (not staging)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROD_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...prod-anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...prod-service-role-key...

# Test users — from seed:e2e run against production
PLAYWRIGHT_CONSUMER_EMAIL=e2e-consumer@mywealthmaps.test
PLAYWRIGHT_CONSUMER_PASSWORD=E2eTest!2026Mwm
PLAYWRIGHT_HOUSEHOLD_ID=YOUR_PROD_HOUSEHOLD_ID_FROM_SEED

PLAYWRIGHT_ADVISOR_EMAIL=e2e-advisor@mywealthmaps.test
PLAYWRIGHT_ADVISOR_PASSWORD=E2eTest!2026Mwm

PLAYWRIGHT_ATTORNEY_EMAIL=e2e-attorney@mywealthmaps.test
PLAYWRIGHT_ATTORNEY_PASSWORD=E2eTest!2026Mwm

# Stripe — production webhook signing secret
# Get from Stripe Dashboard → Developers → Webhooks → your endpoint
PLAYWRIGHT_STRIPE_WEBHOOK_SECRET=whsec_YOUR_LIVE_WEBHOOK_SECRET

# Stripe — live price IDs (must match Vercel Production env vars)
PLAYWRIGHT_ADVISOR_FIRM_STARTER_PRICE_ID=price_YOUR_LIVE_ADVISOR_STARTER

# Required — test accounts have no TOTP
REQUIRE_PRIVILEGED_MFA=false
