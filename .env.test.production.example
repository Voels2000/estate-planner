# Production E2E smoke — copy to .env.test.production (gitignored). Never commit.
# Run: npm run test:e2e:prod:smoke -- --workers=1
# Target app URL is fixed in scripts/testEnv.ts (www.mywealthmaps.com).
# READ-ONLY for routine smoke: anon key + Playwright logins only.
#
# Track 2 (advisor isolation): linked pair + role canaries seeded on prod.
# Manual proof: npm run track2:prod-link-handcheck
# Reseed: npm run seed:prod-canary / seed:prod-role-canaries / seed:prod-advisor-firm -- --confirm

TEST_ENV=production
I_KNOW_THIS_IS_PRODUCTION=yes

# CONSISTENCY CHECK: production Supabase ref must be fnzvlmrqwcqwiqueevux
NEXT_PUBLIC_SUPABASE_URL=https://fnzvlmrqwcqwiqueevux.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Logged-in consumer canary (also the linked client for advisor isolation)
PLAYWRIGHT_CONSUMER_EMAIL=canary-consumer@mywealthmaps.com
PLAYWRIGHT_CONSUMER_PASSWORD=

# Linked consumer for invite→accept fixture (same account on prod Track 2)
PLAYWRIGHT_CONSUMER_LINK_EMAIL=canary-consumer@mywealthmaps.com
PLAYWRIGHT_CONSUMER_LINK_PASSWORD=

# Isolation foreign household — unlinked canary-advisor-client (advisor must not reach)
PLAYWRIGHT_HOUSEHOLD_ID=
PLAYWRIGHT_ADVISOR_CLIENT_EMAIL=canary-advisor-client@mywealthmaps.com
PLAYWRIGHT_ADVISOR_CLIENT_HOUSEHOLD_ID=
# Owner UUIDs for client-export-payload smokes (read-only smoke — no service role needed).
# Print via: npm run seed:prod-export-markers -- --confirm
PLAYWRIGHT_CONSUMER_USER_ID=
PLAYWRIGHT_CONSUMER_LINK_USER_ID=
PLAYWRIGHT_ADVISOR_CLIENT_USER_ID=

# Signed webhook noop test (live whsec_ from Stripe Dashboard → Webhooks → www endpoint)
# PLAYWRIGHT_STRIPE_WEBHOOK_SECRET=whsec_   # live signing secret from Stripe → Webhooks → www.mywealthmaps.com

PLAYWRIGHT_ADVISOR_EMAIL=canary-advisor@mywealthmaps.com
PLAYWRIGHT_ADVISOR_PASSWORD=

PLAYWRIGHT_ADVISOR_EMPTY_EMAIL=canary-advisor-empty@mywealthmaps.com
PLAYWRIGHT_ADVISOR_EMPTY_PASSWORD=

REQUIRE_PRIVILEGED_MFA=false
