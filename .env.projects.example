# .env.projects.local — BOTH Supabase projects in one place (copy → .env.projects.local).
# Gitignored. Never commit. Never Vercel/GitHub.
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │  HOW THE ENV FILES FIT TOGETHER                                         │
# ├─────────────────────────────────────────────────────────────────────────┤
# │  .env.projects.local   STAGING_* + PROD_* Supabase creds (this file)     │
# │  .env.local            Active local dev — copy STAGING_* here (Next.js) │
# │  .env.test.local       Playwright E2E users + household IDs (local server) │
# │  .env.test.staging     Playwright against staging Vercel deployment      │
# │  .env.test.production  Production smoke only (@production tests)         │
# │  Vercel dashboard      Deployed secrets (Production + Preview scopes)   │
# └─────────────────────────────────────────────────────────────────────────┘
#
# Next.js only reads unprefixed vars in .env.local — it cannot use STAGING_* directly.
# After editing STAGING_* below, copy those four values into .env.local (or run:
#   bash scripts/sync-env-from-projects.sh staging
# ).

# ═══ STAGING (mwm-staging) — local dev + Vercel Preview ═══
STAGING_NEXT_PUBLIC_SUPABASE_URL=https://YOUR_STAGING_REF.supabase.co
STAGING_NEXT_PUBLIC_SUPABASE_ANON_KEY=
STAGING_SUPABASE_SERVICE_ROLE_KEY=
# Session pooler URI (IPv4). Direct db.* host is IPv6-only on many Mac networks.
STAGING_SUPABASE_DB_URL=postgresql://postgres.YOUR_STAGING_REF:password@aws-1-us-west-2.pooler.supabase.com:5432/postgres

# ═══ PRODUCTION — scripts only (canary seed, cleanup dry-run). Never local dev. ═══
PROD_NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROD_REF.supabase.co
PROD_NEXT_PUBLIC_SUPABASE_ANON_KEY=
PROD_SUPABASE_SERVICE_ROLE_KEY=
PROD_SUPABASE_DB_URL=postgresql://postgres.YOUR_PROD_REF:password@aws-0-us-west-2.pooler.supabase.com:5432/postgres
