# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.env.*.check
!.env.local.example
!.env.projects.example
!.env.test.example
!.env.test.local.example
!.env.test.staging.example
!.env.test.production.example
!.env.test.prod.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Playwright
node_modules/
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/

# Playwright auth state (Sprint 75)
.auth/
tsc.log
supabase/.temp/
audit-results.txt
audit-summary.txt
security-audit-results.txt
tools/launch-tracker-state.json

# Directory outreach seed spreadsheets (PII — local handoff only)
/data/directory-seed/*.xlsx
/data/directory-seed/*.xls
/data/directory-seed/*.csv

# Sentry Config File
.env.sentry-build-plugin
