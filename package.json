    "test:e2e:partial-patch": "dotenv -o -e .env.test -- npx playwright test tests/e2e/consumer/consumer-profile-save.spec.ts --project=consumer --grep \"partial PATCH\" --workers=1",
    "test:e2e:nightly": "dotenv -o -e .env.test -- npx playwright test --project=public",
    "// E2E production smoke — requires .env.test.prod (never committed)": "",
