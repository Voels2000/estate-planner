{
  "name": "estate-planner",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:e2e": "dotenv -e .env.test -- npx playwright test",
    "test:e2e:advisor": "dotenv -e .env.test -- npx playwright test --project=advisor-setup --project=advisor",
    "test:e2e:consumer": "dotenv -e .env.test -- npx playwright test --project=consumer-setup --project=consumer",
    "test:e2e:public": "dotenv -e .env.test -- npx playwright test --project=public",
    "test:e2e:regression": "dotenv -e .env.test -- npx playwright test tests/e2e/advisor/regression.spec.ts",
    "test:e2e:report": "npx playwright show-report"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-email/render": "^2.0.4",
    "@react-pdf/renderer": "^4.3.2",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.1",
    "@tailwindcss/typography": "^0.5.19",
    "date-fns": "^4.1.0",
    "mammoth": "^1.12.0",
    "next": "16.1.6",
    "papaparse": "^5.5.3",
    "pdf-parse": "^2.4.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "resend": "^6.9.3",
    "stripe": "^17.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
