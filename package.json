{
  "name": "estate-planner",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:e2e": "dotenv -e .env.test -- npx playwright test",
    "test:e2e:advisor": "dotenv -e .env.test -- npx playwright test --project=advisor-setup --project=advisor",
    "test:e2e:consumer": "dotenv -e .env.test -- npx playwright test --project=consumer-setup --project=consumer",
    "test:e2e:public": "dotenv -e .env.test -- npx playwright test --project=public",
    "test:e2e:attorney": "dotenv -e .env.test -- npx playwright test --project=attorney-setup --project=attorney",
    "test:e2e:complete": "dotenv -e .env.test -- npx playwright test --project=consumer-setup --project=consumer --project=advisor-setup --project=advisor --project=attorney-setup --project=attorney --project=public",
    "test:e2e:nightly": "dotenv -e .env.test -- npx playwright test --project=public",
    "test:e2e:regression": "dotenv -e .env.test -- npx playwright test tests/e2e/advisor/regression.spec.ts",
    "test:e2e:golden-path": "dotenv -e .env.local -e .env.test -- npx playwright test --project=golden-path",
    "seed:golden-path": "dotenv -e .env.local -e .env.test -- npx tsx scripts/seed-golden-path-stage1.ts",
    "test:e2e:report": "npx playwright show-report",
    "test:import:unit": "npx playwright test --project=import-unit",
    "test:import:api": "dotenv -e .env.test -- npx playwright test tests/e2e/consumer/consumer-import.spec.ts --project=consumer --workers=1",
    "seed:e2e": "dotenv -e .env.local -e .env.test -- npx tsx scripts/seed-e2e-fixtures.ts",
    "verify:e2e-auth": "dotenv -e .env.local -e .env.test -- npx tsx scripts/verify-e2e-auth.ts",
    "seed:e2e:fast": "dotenv -e .env.local -e .env.test -- npx tsx scripts/seed-e2e-fixtures.ts --skip-johnson",
    "prune:e2e": "dotenv -e .env.local -e .env.test -- npx tsx scripts/prune-e2e-household-artifacts.ts",
    "verify:drip": "dotenv -e .env.local -- npx tsx scripts/verify-drip-sequence.ts",
    "cleanup:rolobe": "dotenv -e .env.local -- npx tsx scripts/cleanup-test-accounts.ts --rolobe",
    "verify:deletion": "dotenv -e .env.local -- npx tsx scripts/verify-deletion.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-email/render": "^2.0.4",
    "@react-pdf/renderer": "^4.3.2",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.1",
    "@tailwindcss/typography": "^0.5.19",
    "@vercel/analytics": "^2.0.1",
    "date-fns": "^4.1.0",
    "mammoth": "^1.12.0",
    "next": "16.1.6",
    "papaparse": "^5.5.3",
    "pdf-parse": "^2.4.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "resend": "^6.9.3",
    "stripe": "^17.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
