    "test:e2e:security-smoke": "dotenv -o -e .env.test -- npx playwright test tests/e2e/consumer/security-sprint-rpc-pages.spec.ts --project=consumer tests/e2e/advisor/security-sprint-monte-carlo.spec.ts --project=advisor --workers=1",
