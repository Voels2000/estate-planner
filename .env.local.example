# Copy to .env.local and fill in values (do not commit .env.local)
#
# Supabase (both projects): copy .env.projects.example → .env.projects.local
# Then: bash scripts/sync-env-from-projects.sh staging
# See .env.projects.example for the full file map (.env.test, .env.test.prod, etc.)

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Local-only — post-deploy SQL RLS invariants (npm run verify:rls -- --require-sql).
# Supabase → Connect → Session pooler → Copy. Paste as KEY=value below. Never commit or add to GitHub/Vercel.
# SUPABASE_DB_URL=

STRIPE_SECRET_KEY=sk_live_or_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Consumer price IDs (create in Stripe Dashboard — 3 tiers × monthly/annual)
STRIPE_PRICE_FINANCIAL_MONTHLY=price_...
STRIPE_PRICE_FINANCIAL_ANNUAL=price_...
STRIPE_PRICE_RETIREMENT_MONTHLY=price_...
STRIPE_PRICE_RETIREMENT_ANNUAL=price_...
STRIPE_PRICE_ESTATE_MONTHLY=price_...
STRIPE_PRICE_ESTATE_ANNUAL=price_...
STRIPE_PRICE_PLAN_AND_EXPORT=price_...

RESEND_API_KEY=
CRON_SECRET=
RECOMPUTE_SECRET=
INTERNAL_API_KEY=

# Local smoke only — authoritative homes are Vercel Preview + Production scopes.
# ADMIN_VERIFY_TOKEN=local-dev-placeholder

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Ops inbox for Sprint C-7 compliance cron (daily alerts + monthly summary)
COMPLIANCE_EMAIL=you@example.com

# Privileged MFA (admin / advisor / attorney) — keep false until go-live; E2E uses false.
# Set true in Vercel Production when opening signups: REQUIRE_PRIVILEGED_MFA=true
REQUIRE_PRIVILEGED_MFA=false

# Shared rate limits (optional — falls back to in-memory per instance if unset)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# B2B2C consumer billing handoff — see docs/BILLING_B2B2C_POLICY.md
# Advisor: default ON (omit or any value except false). Set false to keep consumer paying when linked.
B2B2C_ADVISOR_CONSUMER_BILLING=true
B2B2C_ADVISOR_MANAGED_TIER=3
# Attorney: default OFF. Set true when firm-sponsored consumer access is offered in your market.
# B2B2C_ATTORNEY_CONSUMER_BILLING=false
# B2B2C_ATTORNEY_MANAGED_TIER=2

# Attorney firm products (go-live) — create in Stripe Dashboard
# STRIPE_PRICE_ATTORNEY_STARTER_MONTHLY=price_...
# STRIPE_PRICE_ATTORNEY_GROWTH_MONTHLY=price_...
