# E2E secrets for STAGING. Gitignored. No base URL here.
# CONSISTENCY CHECK: every value below must be STAGING. Supabase ref must read cmzyxpxfyvdvbsykjvsg.
# Do NOT set PLAYWRIGHT_BASE_URL here — derived from ENVIRONMENTS in scripts/testEnv.ts.
# Run: npm run test:e2e:staging
# Money-path validation: npm run validate:plan-export-staging -- 2a  (never use dotenv -o)

TEST_ENV=staging

# Test user logins (app login flow)
E2E_TIER1_EMAIL=e2e-consumer-tier1@mywealthmaps.test
E2E_TIER1_PASSWORD=<staging test user password>

# Admin endpoints (only if tests hit /api/admin/*)
ADMIN_VERIFY_TOKEN=<staging admin token>

# Direct DB for setup/teardown (only if tests seed/clean Supabase directly)
SUPABASE_URL=https://cmzyxpxfyvdvbsykjvsg.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<staging service role key>

# Stripe — ONLY if tests verify/clean Stripe objects directly
# (the app uses its own key on Vercel; this is for the runner's own calls)
STRIPE_SECRET_KEY=<staging sandbox test key ending j8UN>

# Optional — full Playwright suite against staging (from npm run seed:e2e output)
# PLAYWRIGHT_HOUSEHOLD_ID=
# PLAYWRIGHT_ADVISOR_CLIENT_HOUSEHOLD_ID=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# PLAYWRIGHT_STRIPE_WEBHOOK_SECRET=
# PLAYWRIGHT_ADVISOR_FIRM_STARTER_PRICE_ID=
